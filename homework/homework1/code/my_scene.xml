<?xml version="1.0" encoding="utf-8"?>

<scene version="0.5.0">
	<integrator type="path">
		<integer name="maxDepth" value="12"/>
	</integrator>

	<!-- Rock Hyrax with furry appearance -->
	<shape type="obj">
		<string name="filename" value="hyrax.obj"/>

		<transform name="toWorld">
			<translate x="6.1" y="-1.3" z="0.5"/>
			<rotate y="1" angle="30"/>
			<scale value="1"/>
		</transform>

		<!-- Disney BSDF configured for realistic furry hyrax appearance -->
		<bsdf type="disneybsdf">
			<!-- Base color: Much darker brownish-gray to reduce brightness -->
			<rgb name="baseColor" value="0.05 0.04 0.03"/>

			<!-- High roughness for matte fur appearance -->
			<float name="roughness" value="0.95"/>

			<!-- NO subsurface - it was making it too bright -->
			<float name="subsurface" value="0.0"/>

			<!-- Very low specular for fur (not shiny) -->
			<float name="specular" value="0.05"/>

			<!-- High sheen for fluffy/fuzzy appearance -->
			<float name="sheen" value="0.8"/>

			<!-- Sheen tint: warm tone to match fur color -->
			<float name="sheenTint" value="0.5"/>

			<!-- No metallic - fur is organic -->
			<float name="metallic" value="0.0"/>

			<!-- Minimal specular tint -->
			<float name="specularTint" value="0.0"/>

			<!-- No anisotropy for fur -->
			<float name="anisotropic" value="0.0"/>

			<!-- No clearcoat for natural fur -->
			<float name="clearcoat" value="0.0"/>
			<float name="clearcoatGloss" value="0.0"/>

			<!-- No transmission - fur is opaque -->
			<float name="specularTransmission" value="0.0"/>

			<!-- IOR (not used since no transmission) -->
			<float name="eta" value="1.5"/>
		</bsdf>
	</shape>

	<!-- Camera setup -->
	<sensor type="perspective">
    <float name="fov" value="70"/>
    <transform name="toWorld">
        <lookAt target="3.5, 0.8, 0.5" origin="3.0, 1.5, 2.5" up="0, 1, 0"/>
    </transform>

    <sampler type="independent">
        <integer name="sampleCount" value="1024"/>
    </sampler>

    <film type="hdrfilm">
        <integer name="width" value="960"/>
        <integer name="height" value="540"/>
        <rfilter type="gaussian"/>
    </film>
</sensor>


	<!-- Environment map using rock.exr for realistic HDRI lighting and background -->
	<emitter type="envmap">
		<string name="filename" value="rock.exr"/>
		<transform name="toWorld">
			<rotate y="1" angle="90"/>
		</transform>
		<float name="scale" value="1.2"/>
	</emitter>
</scene>
