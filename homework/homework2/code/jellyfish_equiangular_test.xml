<?xml version="1.0" encoding="utf-8"?>

<scene version="0.5.0">
	<!-- Use version 2 for single scattering with equiangular sampling comparison -->
	<!-- Simplified scene: just the glowing core in ocean medium (no glass surfaces) -->
	<!-- This demonstrates equiangular sampling for a small light in participating media -->
	<integrator type="volpath">
		<integer name="maxDepth" value="2"/>
		<integer name="version" value="2"/>
	</integrator>

	<!-- Ocean medium - scattering medium -->
	<medium type="homogeneous" id="ocean">
		<rgb name="sigmaA" value="0.02 0.008 0.002"/>
		<rgb name="sigmaS" value="0.015 0.012 0.008"/>
		<float name="scale" value="1"/>
	</medium>

	<!-- Jellyfish core - small cyan light source in scattering medium -->
	<!-- A small light in participating medium is ideal for equiangular sampling -->
	<!-- Equiangular sampling importance samples the 1/r^2 geometry term -->
	<shape type="obj">
		<string name="filename" value="jellyfish_core.obj"/>
		<transform name="toWorld">
			<scale x="0.7" y="0.7" z="0.7"/>
		</transform>

		<bsdf type="diffuse">
			<rgb name="reflectance" value="0.0 0.0 0.0"/>
		</bsdf>

		<emitter type="area">
			<rgb name="radiance" value="0.8 3.0 4.0"/>
		</emitter>
	</shape>

	<!-- Sunlight from above -->
	<shape type="sphere">
		<point name="center" x="5" y="35" z="-10"/>
		<float name="radius" value="10"/>

		<emitter type="area">
			<rgb name="radiance" value="0.6 0.8 1.0"/>
		</emitter>

		<bsdf type="diffuse">
			<rgb name="reflectance" value="0.0 0.0 0.0"/>
		</bsdf>

		<ref name="exterior" id="ocean"/>
	</shape>

	<!-- Camera setup -->
	<sensor type="perspective">
		<string name="fovAxis" value="x"/>
		<float name="fov" value="45"/>
		<transform name="toWorld">
			<lookAt target="0, 0, 0" origin="18, 2, 18" up="0, 1, 0"/>
		</transform>

		<sampler type="independent">
			<integer name="sampleCount" value="256"/>
		</sampler>

		<film type="hdrfilm" id="film">
			<integer name="width" value="512"/>
			<integer name="height" value="512"/>
			<string name="pixelFormat" value="rgb"/>
			<boolean name="banner" value="false"/>

			<rfilter type="gaussian"/>
		</film>

		<ref id="ocean"/>
	</sensor>
</scene>
